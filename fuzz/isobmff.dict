# ISOBMFF/HEIF/AVIF fuzzing dictionary for zenavif-parse
# Generated from parser source code and ISOBMFF/HEIF/AVIF specifications
#
# Box types, brands, handler types, item types, reference types,
# color types, AV1 codec config bytes, OBU markers, auxiliary URNs,
# and structural patterns used by the parser.

# ============================================================
# File-level box types (4-byte FourCC, big-endian)
# ============================================================
box_ftyp="ftyp"
box_mdat="mdat"
box_moov="moov"
box_meta="meta"
box_free="free"
box_skip="skip"
box_wide="wide"
box_moof="moof"
box_uuid="uuid"

